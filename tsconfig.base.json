{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@saas/shared": ["packages/shared/src/index.ts"],
      "@saas/validation": ["packages/validation/src/index.ts"],
      "@saas/db": ["packages/db/src/index.ts"],
      "@repo/ui": ["packages/ui/index.ts"],
      "@repo/ui/*": ["packages/ui/*"]
    }
  }
}
